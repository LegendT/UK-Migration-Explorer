{
  "name": "uk-migration-explorer",
  "version": "0.1.0",
  "description": "A plain-English guide to what UK migration and asylum statistics do, and do not, show.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node scripts/validate-data.mjs && node scripts/validate-content.mjs",
    "validate": "node scripts/validate-data.mjs --verbose && node scripts/validate-content.mjs",
    "check-sources": "node scripts/check-sources.mjs",
    "build": "rm -rf _site && eleventy && node scripts/check-build.mjs",
    "serve": "eleventy --serve",
    "check-build": "node scripts/check-build.mjs",
    "a11y": "npm run build && npx --yes start-server-and-test a11y:serve http://127.0.0.1:8081 a11y:ci",
    "a11y:serve": "npx --yes http-server _site -p 8081 -s -c-1",
    "a11y:ci": "npx --yes pa11y-ci"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LegendT/UK-Migration-Explorer.git"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6"
  }
}
