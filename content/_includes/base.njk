<!doctype html>
<html lang="en-GB">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if claim %}Claim checked: {{ claim }} | {{ site.name }}{% elif title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
<meta name="description" content="{{ short_answer or strapline or site.strapline }}">
<link rel="stylesheet" href="/assets/style.css">
</head>
<body>
<a class="skip-link" href="#main">Skip to main content</a>

<div class="prelaunch" role="note">
  <p class="wrap">
    <strong>This site is not finished.</strong> Its update commitment is not yet signed off and
    the pre-publication review it promises has not happened. Figures are sourced and checked.
    <a href="/about/">Who runs it and who pays</a>,
    <a href="/sources-and-method/#updates">what is outstanding</a>.
  </p>
</div>

<header class="site-header">
  <div class="wrap">
    <p class="brand"><a href="/">{{ site.name }}</a></p>
    <nav aria-label="Main">
      <ul>
        {%- for item in site.nav %}
        <li><a href="{{ item.href }}"{% if page.url == item.href %} aria-current="page"{% endif %}>{{ item.label }}</a></li>
        {%- endfor %}
      </ul>
    </nav>
  </div>
</header>

<main id="main" class="wrap">
  {% if title and not suppressPageHeader %}
  <header class="page-header">
    <h1>{{ title }}</h1>
    {% if strapline %}<p class="strapline">{{ strapline }}</p>{% endif %}
  </header>
  {% endif %}

  {{ content | safe }}

  {% if last_reviewed %}
  <p class="reviewed">Last reviewed {{ last_reviewed | longDate }}.
  Figures are the latest published at that date, not a live count.</p>
  {% endif %}
</main>

<footer class="site-footer">
  <div class="wrap">
    <p>{{ site.strapline }}</p>
    <p>{{ meta.footerNote }}</p>
    <p>Contains public sector information licensed under the
      <a href="http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/">Open Government Licence v3.0</a>.
      <a href="https://github.com/LegendT/UK-Migration-Explorer">Source and data on GitHub</a>.</p>
    <p><strong>Found an error?</strong> Tell us which figure and what you think it should be:
      <a href="https://github.com/LegendT/UK-Migration-Explorer/issues/new">report it here</a>.
      Every change to a published figure is recorded in the
      <a href="https://github.com/LegendT/UK-Migration-Explorer/blob/main/CHANGELOG.md">public changelog</a>.</p>
  </div>
</footer>
</body>
</html>
